# 이 프로젝트 전용 Discord 봇 토큰
# Discord Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Claude Code에서 메시지를 수신할 Discord 채널 ID (쉼표 구분)
ALLOWED_CHANNEL_IDS=

# 봇에게 메시지를 보낼 수 있는 Discord 사용자 ID (쉼표 구분)
# 개발자 모드 켜고 사용자 우클릭 → ID 복사
ALLOWED_USER_IDS=

# 채널에서 봇 멘션(@) 필요 여부 (true/false)
REQUIRE_MENTION=true

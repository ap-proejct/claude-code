# BillAlarmBot 설정 파일
# 이 파일을 복사해서 .env로 저장한 후 값을 채워주세요.
# cp .env.example .env

# ─── Google API ───────────────────────────────────────────
# 서비스 계정 JSON 파일명 (src/main/resources/ 아래에 저장)
GOOGLE_CREDENTIALS_PATH=billalarmbot.json

# Google Sheets 스프레드시트 ID (URL의 /d/ 뒤 값)
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Calendar ID (캘린더 설정 → 캘린더 통합 섹션에서 확인)
CALENDAR_ID=your_calendar_id_here

# ─── Telegram ─────────────────────────────────────────────
# BotFather에서 발급받은 Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 알림을 받을 Telegram Chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── 스케줄러 ──────────────────────────────────────────────
# 매일 알림을 보낼 시각 (기본: 매일 오전 9시)
# 형식: 초 분 시 일 월 요일
SCHEDULER_CRON=0 0 9 * * *

# ─── 데이터베이스 ──────────────────────────────────────────
# MySQL 비밀번호 (기본값 그대로 사용해도 무방)
MYSQL_PASSWORD=billalarm1234
MYSQL_ROOT_PASSWORD=root1234
